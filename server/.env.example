PORT=5000
NODE_ENV=development

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?appName=<AppName>

# JWT signing secret (use a strong random string)
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# Google Gemini API Key
# Get one at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Murf AI Text-to-Speech API Key
# Get one at: https://murf.ai/api
MURF_API_KEY=your_murf_api_key_here

# AssemblyAI Speech-to-Text API Key
# Get one at: https://www.assemblyai.com/
ASSEMBLYAI_API_KEY=your_assemblyai_api_key_here

# URL of the running React client (for CORS)
CLIENT_URL=http://localhost:5173
